    "_postman_id": "e26f81c4-5c1d-4803-919f-6fa853757ebd",
    "name": "Flagsmith Flags API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Flagsmith Flags API is the public-facing REST API that client-side and server-side SDKs use to retrieve feature flag values and remote configuration for environments and users. It uses a non-secret Environment Key for authentication and is designed to be fast, scalable, and publicly accessible. The Edge API endpoint at edge.api.flagsmith.com serves requests from AWS Lambda functions running in data centers near the client, providing low-latency global access to flag evaluations.\n\nContact Support:\n Name: Flagsmith Support",
      "type": "text/plain"
    }
  }
